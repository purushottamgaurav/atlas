@model Job

@{
    ViewData["Title"] = "Delete Job";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-danger border-0 shadow-sm">
            <div class="card-header bg-danger text-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
            </div>
            <div class="card-body p-4">
                <p class="mb-4">Are you sure you want to delete the following job posting? This will also delete all associated applications and cannot be undone.</p>

                <div class="bg-light rounded p-3 mb-4">
                    <h5 class="fw-bold mb-1">@Model.Title</h5>
                    <p class="text-muted mb-1"><i class="bi bi-building me-1"></i>@Model.Company</p>
                    <p class="text-muted mb-1"><i class="bi bi-geo-alt me-1"></i>@Model.Location</p>
                    <p class="text-muted mb-0"><i class="bi bi-briefcase me-1"></i>@Model.JobType</p>
                </div>

                <form asp-action="Delete" asp-route-id="@Model.JobId" method="post" class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger btn-lg">
                        <i class="bi bi-trash me-2"></i>Yes, Delete
                    </button>
                    <a asp-action="MyJobs" class="btn btn-outline-secondary btn-lg">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
