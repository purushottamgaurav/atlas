@model JobListViewModel

@{
    ViewData["Title"] = "Browse Jobs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 fw-bold mb-0">Browse Jobs</h1>
        <p class="text-muted mb-0">@Model.TotalCount job@(Model.TotalCount != 1 ? "s" : "") found</p>
    </div>
    @if (ViewBag.IsEmployer == true)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Post a Job
        </a>
    }
</div>

<div class="row g-4">
    <!-- Sidebar Filters -->
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm p-3 sticky-top" style="top: 80px;">
            <h6 class="fw-bold mb-3"><i class="bi bi-sliders me-2"></i>Filter Jobs</h6>
            <partial name="_SearchForm" model="Model" />
        </div>
    </div>

    <!-- Job Listings -->
    <div class="col-lg-9">
        @if (!Model.Jobs.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-search display-1 text-muted"></i>
                <h5 class="mt-3 text-muted">No jobs found</h5>
                <p class="text-muted">Try adjusting your search or filters.</p>
                <a asp-action="Index" class="btn btn-outline-primary">Clear Filters</a>
            </div>
        }
        else
        {
            <div class="row g-3 mb-4">
                @foreach (var job in Model.Jobs)
                {
                    <div class="col-md-6 col-xl-4">
                        <partial name="_JobCard" model="job" />
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Job listings pagination">
                    <ul class="pagination justify-content-center">
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-jobType="@Model.SelectedJobType"
                                   asp-route-location="@Model.SelectedLocation"
                                   asp-route-page="@(Model.CurrentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-jobType="@Model.SelectedJobType"
                                   asp-route-location="@Model.SelectedLocation"
                                   asp-route-page="@i">@i</a>
                            </li>
                        }
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-jobType="@Model.SelectedJobType"
                                   asp-route-location="@Model.SelectedLocation"
                                   asp-route-page="@(Model.CurrentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>
