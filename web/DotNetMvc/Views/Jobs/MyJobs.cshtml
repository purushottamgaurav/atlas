@model List<Job>

@{
    ViewData["Title"] = "My Job Postings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 fw-bold mb-0">My Job Postings</h1>
        <p class="text-muted mb-0">@Model.Count posting@(Model.Count != 1 ? "s" : "")</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Post New Job
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-briefcase display-1 text-muted"></i>
        <h5 class="mt-3 text-muted">No jobs posted yet</h5>
        <p class="text-muted">Start by posting your first job opening.</p>
        <a asp-action="Create" class="btn btn-primary">Post a Job</a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Job Title</th>
                        <th>Type</th>
                        <th>Location</th>
                        <th class="text-center">Applications</th>
                        <th class="text-center">Status</th>
                        <th>Posted</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="Details" asp-route-id="@job.JobId" class="fw-semibold text-decoration-none">
                                    @job.Title
                                </a>
                                @if (job.ApplicationDeadline.HasValue && job.ApplicationDeadline < DateTime.UtcNow)
                                {
                                    <span class="badge bg-secondary ms-1 small">Expired</span>
                                }
                            </td>
                            <td><span class="badge bg-light text-dark border">@job.JobType</span></td>
                            <td class="text-muted small">@job.Location</td>
                            <td class="text-center">
                                <a asp-controller="Applications" asp-action="ReviewApplications" asp-route-jobId="@job.JobId"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-people me-1"></i>@job.Applications.Count
                                </a>
                            </td>
                            <td class="text-center">
                                @if (job.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-muted small">@job.PostedDate.ToString("MMM d, yyyy")</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="Edit" asp-route-id="@job.JobId" class="btn btn-sm btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@job.JobId" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
