@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="h3 fw-bold mb-1">Dashboard</h1>
<p class="text-muted mb-4">
    @if (Model.UserRole == UserRole.Employer)
    {
        <span><i class="bi bi-building me-1"></i>Employer Overview</span>
    }
    else
    {
        <span><i class="bi bi-person me-1"></i>Job Seeker Overview</span>
    }
</p>

@if (Model.UserRole == UserRole.Employer)
{
    <!-- Employer Stats -->
    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card text-center p-4">
                <div class="stat-number text-primary">@Model.MyJobs.Count</div>
                <div class="text-muted">Jobs Posted</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card text-center p-4">
                <div class="stat-number text-success">@Model.ActiveJobCount</div>
                <div class="text-muted">Active Listings</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card text-center p-4">
                <div class="stat-number text-warning">@Model.TotalApplicationsReceived</div>
                <div class="text-muted">Total Applications</div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0">Recent Job Postings</h5>
        <a asp-controller="Jobs" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Post New Job
        </a>
    </div>

    @if (!Model.MyJobs.Any())
    {
        <div class="text-center py-4">
            <p class="text-muted">No jobs posted yet. <a asp-controller="Jobs" asp-action="Create">Post your first job!</a></p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Type</th>
                            <th class="text-center">Apps</th>
                            <th class="text-center">Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model.MyJobs.Take(5))
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.JobId"
                                       class="text-decoration-none fw-semibold">@job.Title</a>
                                    <div class="text-muted small">@job.Location</div>
                                </td>
                                <td><span class="badge bg-light text-dark border">@job.JobType</span></td>
                                <td class="text-center">
                                    <a asp-controller="Applications" asp-action="ReviewApplications" asp-route-jobId="@job.JobId"
                                       class="text-decoration-none">
                                        <strong>@job.Applications.Count</strong>
                                    </a>
                                </td>
                                <td class="text-center">
                                    @if (job.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Jobs" asp-action="Edit" asp-route-id="@job.JobId"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (Model.MyJobs.Count > 5)
        {
            <div class="text-center mt-3">
                <a asp-controller="Jobs" asp-action="MyJobs" class="btn btn-outline-primary btn-sm">
                    View All @Model.MyJobs.Count Postings
                </a>
            </div>
        }
    }
}
else
{
    <!-- Job Seeker Stats -->
    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card text-center p-4">
                <div class="stat-number text-primary">@Model.MyApplications.Count</div>
                <div class="text-muted">Applications Sent</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card text-center p-4">
                <div class="stat-number text-warning">@Model.PendingCount</div>
                <div class="text-muted">Pending Review</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card text-center p-4">
                <div class="stat-number text-success">@Model.AcceptedCount</div>
                <div class="text-muted">Accepted</div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0">Recent Applications</h5>
        <a asp-controller="Jobs" asp-action="Index" class="btn btn-primary btn-sm">
            <i class="bi bi-search me-1"></i>Browse More Jobs
        </a>
    </div>

    @if (!Model.MyApplications.Any())
    {
        <div class="text-center py-4">
            <p class="text-muted">No applications yet. <a asp-controller="Jobs" asp-action="Index">Browse jobs</a> and apply!</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Position</th>
                            <th>Company</th>
                            <th>Applied</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.MyApplications.Take(5))
                        {
                            var badgeClass = app.Status switch
                            {
                                ApplicationStatus.Accepted => "bg-success",
                                ApplicationStatus.Rejected => "bg-danger",
                                ApplicationStatus.UnderReview => "bg-warning text-dark",
                                _ => "bg-secondary"
                            };
                            <tr>
                                <td>
                                    <a asp-controller="Jobs" asp-action="Details" asp-route-id="@app.JobId"
                                       class="text-decoration-none fw-semibold">@(app.Job?.Title ?? "Unknown")</a>
                                </td>
                                <td class="text-muted">@(app.Job?.Company ?? "—")</td>
                                <td class="text-muted small">@app.AppliedDate.ToString("MMM d, yyyy")</td>
                                <td class="text-center"><span class="badge @badgeClass">@app.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (Model.MyApplications.Count > 5)
        {
            <div class="text-center mt-3">
                <a asp-controller="Applications" asp-action="MyApplications" class="btn btn-outline-primary btn-sm">
                    View All @Model.MyApplications.Count Applications
                </a>
            </div>
        }
    }
}
