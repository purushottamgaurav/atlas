@model ProfileSetupViewModel

@{
    ViewData["Title"] = "Set Up Your Profile";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="text-center mb-4">
            <h1 class="h2 fw-bold mb-1"><i class="bi bi-briefcase-fill text-primary me-2"></i>Welcome to JobBoard</h1>
            <p class="text-muted">Let's set up your profile. This takes less than a minute.</p>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Setup" method="post" id="setupForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                    <div class="mb-4">
                        <label asp-for="DisplayName" class="form-label fw-semibold"></label>
                        <input asp-for="DisplayName" class="form-control form-control-lg" placeholder="How should we address you?" />
                        <span asp-validation-for="DisplayName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold d-block mb-3">I am a...</label>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="role-card d-block p-4 rounded-3 border cursor-pointer text-center" id="card-jobseeker">
                                    <input type="radio" asp-for="Role" value="@UserRole.JobSeeker" class="d-none role-radio" />
                                    <i class="bi bi-person-workspace fs-1 d-block mb-2 text-success"></i>
                                    <div class="fw-bold fs-5">Job Seeker</div>
                                    <p class="text-muted small mb-0">Browse jobs, apply, and track your applications.</p>
                                </label>
                            </div>
                            <div class="col-md-6">
                                <label class="role-card d-block p-4 rounded-3 border cursor-pointer text-center" id="card-employer">
                                    <input type="radio" asp-for="Role" value="@UserRole.Employer" class="d-none role-radio" />
                                    <i class="bi bi-building-fill-gear fs-1 d-block mb-2 text-primary"></i>
                                    <div class="fw-bold fs-5">Employer</div>
                                    <p class="text-muted small mb-0">Post jobs, review applicants, and hire great talent.</p>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>

                    <div class="mb-4" id="companySection" style="display:none;">
                        <label asp-for="CompanyName" class="form-label fw-semibold"></label>
                        <input asp-for="CompanyName" class="form-control" placeholder="Your company or organisation name" />
                        <span asp-validation-for="CompanyName" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-arrow-right-circle me-2"></i>Complete Setup
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const radios = document.querySelectorAll('.role-radio');
        const companySection = document.getElementById('companySection');
        const cards = document.querySelectorAll('.role-card');

        function updateCards() {
            cards.forEach(card => {
                const radio = card.querySelector('.role-radio');
                card.classList.toggle('role-card-selected', radio.checked);
            });
            const employerSelected = document.querySelector('[value="Employer"]').checked;
            companySection.style.display = employerSelected ? 'block' : 'none';
        }

        radios.forEach(radio => radio.addEventListener('change', updateCards));

        // Pre-select if validation failed and value persists
        updateCards();
    </script>
}
