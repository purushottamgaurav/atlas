<UserControl x:Class="DotNetWpf.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotNetWpf.ViewModels"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="440"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Center card -->
        <Border Grid.Column="1"
                Style="{StaticResource Card}"
                VerticalAlignment="Center"
                Margin="0,40">

            <StackPanel>

                <!-- Logo / Title -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="⚡ QuizBlitz"
                               Style="{StaticResource TitleText}"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="32"/>
                    <TextBlock Text="Multiplayer Quiz Game"
                               Style="{StaticResource SubtleText}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Register-only fields -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Username"
                               Style="{StaticResource SubtleText}"
                               Margin="0,0,0,6"
                               Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Email -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Email" Style="{StaticResource SubtleText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Password -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Password" Style="{StaticResource SubtleText}" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"/>
                </StackPanel>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorText}"
                           Margin="0,0,0,12"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Submit button -->
                <Button Command="{Binding SubmitCommand}"
                        Margin="0,0,0,10"
                        Height="44">
                    <Button.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Login"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Text" Value="Please wait..."/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRegisterMode}" Value="True">
                                            <Setter Property="Text" Value="Register"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button.Content>
                </Button>

                <!-- Toggle link -->
                <Button Command="{Binding ToggleModeCommand}"
                        Style="{StaticResource GhostButton}"
                        Height="36">
                    <Button.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="New here? Create an account"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRegisterMode}" Value="True">
                                            <Setter Property="Text" Value="Already have an account? Login"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button.Content>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
