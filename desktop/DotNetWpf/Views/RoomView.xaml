<UserControl x:Class="DotNetWpf.Views.RoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{Binding QuizTitle}" Style="{StaticResource TitleText}"/>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Room Code: " Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding RoomCode}"
                           Style="{StaticResource HeadingText}"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="24"
                           FontWeight="Bold"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Player list -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource HeadingText}" Margin="0,0,0,16">
                    <Run Text="Players ("/>
                    <Run Text="{Binding Players.Count}"/>
                    <Run Text=")"/>
                </TextBlock>

                <!-- Countdown overlay -->
                <Border Visibility="{Binding IsCountingDown, Converter={StaticResource BoolToVisibilityConverter}}"
                        HorizontalAlignment="Center" Margin="0,20">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Game starting in"
                                   Style="{StaticResource HeadingText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Countdown}"
                                   FontSize="72"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Players}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8"
                                        Background="{StaticResource SurfaceBrush}"
                                        Padding="14,10"
                                        Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10"
                                                 Fill="{StaticResource SuccessBrush}"
                                                 Margin="0,0,10,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Username}"
                                                   Style="{StaticResource BodyText}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Footer actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Leave Room"
                    Command="{Binding LeaveRoomCommand}"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,12,0"/>
            <Button Content="Start Game ▶"
                    Command="{Binding StartGameCommand}"
                    Visibility="{Binding IsHost, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="44"
                    Padding="24,10"/>
        </StackPanel>
    </Grid>
</UserControl>
