<Application x:Class="DotNetWpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotNetWpf.ViewModels"
             xmlns:views="clr-namespace:DotNetWpf.Views"
             xmlns:conv="clr-namespace:DotNetWpf.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters (app-wide) -->
            <conv:BoolToVisibilityConverter   x:Key="BoolToVisibilityConverter"/>
            <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <conv:NullToVisibilityConverter   x:Key="NullToVisibilityConverter"/>

            <!-- ViewModel → View mapping (ContentControl DataTemplates) -->
            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                <views:LoginView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:LobbyViewModel}">
                <views:LobbyView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RoomViewModel}">
                <views:RoomView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:GameViewModel}">
                <views:GameView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ResultsViewModel}">
                <views:ResultsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
